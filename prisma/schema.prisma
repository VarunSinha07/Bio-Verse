generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String          @id
  email                     String          @unique
  name                      String?
  userRole                  String?         @default("user")
  emailVerified             Boolean
  image                     String?
  createdAt                 DateTime
  updatedAt                 DateTime
  hasCompletedQuestionnaire Boolean         @default(false)
  stage                     String?
  status                    String?
  requestStatus             String?         // Can be 'approve' or 'decline' or null (for pending)
  programAllocated          String?
  accounts                  Account[]
  sessions                  Session[]
  questionnaires            Questionnaire[]
  businessPlans             BusinessPlan[]
  documents                 Document[]
  meetings                  Meeting[]
  feedbacks                 Feedback[]      // New relation for feedback
  programAllotment          ProgramAllotment?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Questionnaire {
  id              String   @id @default(cuid())
  userId          String
  name            String
  role            String   @default("founder")
  ideaTitle       String
  ideaDescription String   @db.Text
  startUpName     String?
  website         String?
  industry        String
  stage           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("questionnaire")
}

model BusinessPlan {
  id                     String   @id @default(cuid())
  userId                 String
  problemStatement       String   @db.Text
  targetAudience         String   @db.Text
  revenueModel           String   @db.Text
  uniqueValueProposition String   @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @default(now()) @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("business_plan")
}

model Document {
  id                 String   @id @default(cuid())
  userId             String
  competitorAnalysis String?
  foundersProfile    String?
  productMockups     String?
  marketResearch     String?
  signedNDA          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @default(now()) @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("document")
}

model Meeting {
  id          String    @id @default(cuid())
  userId      String
  mentorId    String?
  date        DateTime
  time        String
  link        String
  isCompleted Boolean   @default(false)  // Flag to track completed meetings
  feedback    Feedback? // One-to-one relation with feedback
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("meeting")
}

// New model for meeting feedback
model Feedback {
  id         String   @id @default(cuid())
  meetingId  String   @unique
  userId     String
  feedbackText String  @db.Text
  decision   String   // 'approve', 'decline'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  meeting    Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("feedback")
}

model ProgramAllotment {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  acceptanceConfirmation Boolean  @default(false)
  startDate              String
  resourceRequirements   String   @db.Text
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("program_allotment")
}